  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 28px;
  min-height: 72px;
  background: #ffffff;
  border-bottom: 1px solid #e7eaed;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 50;
  box-shadow: 0 2px 12px rgba(40, 54, 64, 0.06);
}

.brand-lockup {
