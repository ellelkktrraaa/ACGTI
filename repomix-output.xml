import fs from 'fs';
import path from 'path';

const qs = [
  { id: "q1", prompt: "你在派对或者漫展聚会中通常会做什么？", scene: "社交场合", options: [
      { id: "a", label: "主动结识新朋友，聊得很开心", tone: "充满活力", weights: {} },
