}

body {
  margin: 0;
  min-width: 320px;
  font-family: var(--body-font);
  color: var(--text);
  background: var(--bg);
  line-height: 1.6;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
textarea,
select {
  font: inherit;
}

#app {
  min-height: 100vh;
}

/* ============================================
   Site Shell & Layout
   ============================================ */

.site-shell {
  position: relative;
  width: 100%;
  max-width: none;
  margin: 0;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Quiz page overrides for full-screen experience */
.site-shell:has(.quiz-page) {
